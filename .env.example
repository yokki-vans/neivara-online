NODE_ENV=development
PORT=3001
HOST=0.0.0.0
DATABASE_URL=postgresql://neivara:neivara@localhost:5432/neivara
DATABASE_SSL=false
STORAGE_MODE=postgres
JWT_SECRET=replace-with-at-least-32-random-characters
CLIENT_ORIGINS=http://localhost:5173
AUTO_MIGRATE=true
MIGRATION_LOCK_TIMEOUT_MS=10000
# Production defaults to one Railway proxy hop; use false locally or an explicit IP/CIDR list.
TRUST_PROXY=false
WS_MAX_SOCKETS_PER_ACCOUNT=3
LOG_LEVEL=info

# Client build variable (public by design)
VITE_API_URL=http://localhost:3001
